# Encryption E2E topology: minimal cluster with proxy + portal.
# 2 boots, 2 orgs (alpha, bravo): 1 edge + 1 keeper each.
# Seeddrill org added automatically by gen-compose-zoned.sh when PROXY_ENABLED=1.
# Total: ~10 containers (2 boots + 4 org nodes + 3 seeddrill + proxy + portal + orchestrator)

BACKBONE_COUNT=2
BACKBONE_PERSONAL=0
ORG_SPEC=alpha:1:1:0,bravo:1:1:0
IMAGE=cordelia-node:test
BEARER_TOKEN=test-token-fixed
RUST_LOG_LEVEL=warn

GOV_HOT_MIN=1
GOV_HOT_MAX=5
GOV_WARM_MIN=1
GOV_WARM_MAX=5
GOV_COLD_MAX=10

SYNC_MODERATE=5
SYNC_TACITURN=15

PROXY_ENABLED=1
PROXY_IMAGE=cordelia-proxy:test
PROXY_PORT=3847
PORTAL_ENABLED=1
PORTAL_IMAGE=cordelia-portal:test
PORTAL_PORT=3001
